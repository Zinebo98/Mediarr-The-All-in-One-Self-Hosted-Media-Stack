# ─────────────────────────────────────────────────────────────
#  Mediarr — example environment file
#  Copy to .env and fill in YOUR OWN values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# ── Common ───────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=Europe/Berlin

# ── Jellyfin ─────────────────────────────────────────────────
RENDER_GID=
LIBVA_DRIVER_NAME=iHD

# ── AIOMetadata (metadata & catalogs) ────────────────────────
HOST_NAME=http://your-host:3232
TMDB_API_KEY=
TVDB_API_KEY=
GEMINI_API_KEY=
RPDB_API_KEY=
MDBLIST_API_KEY=
# Trakt OAuth app — create at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_REDIRECT_URI=http://your-host:3232/api/auth/trakt/callback

# ── TorBoxarr (debrid download shim) ─────────────────────────
TORBOXARR_TORBOX_API_TOKEN=
TORBOXARR_QBIT_PASSWORD=
TORBOXARR_SAB_API_KEY=

# ── *arr suite ───────────────────────────────────────────────
# API keys are generated inside each app's UI after first run.

# ── jellyfin-reconcile.py ────────────────────────────────────
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=
LIBRARY_ROOTS=/srv/media/library/movies,/srv/media/library/tv,/srv/media/library/anime
